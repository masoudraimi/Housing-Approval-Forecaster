# MLflow tracking server URI
# For local development with docker-compose: http://mlflow:5000
# For local development without docker: http://localhost:5000
MLFLOW_TRACKING_URI=http://localhost:5000

# SQLite prediction log path
PREDICTION_LOG_PATH=data/predictions.db

# Model registry name
MLFLOW_MODEL_NAME=housing-forecast-lstm
MLFLOW_BASELINE_NAME=housing-forecast-baseline

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000
